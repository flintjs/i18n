{
    "name": "@flint.js/i18n",
    "version": "0.1.0",
    "description": "i18n library for @flint.js",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/flintjs/core",
        "directory": "packages/i18n"
    },
    "bugs": "https://github.com/flintjs/core/issues",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "bin": {
        "flint-i18n": "./dist/generate.js"
    },
    "scripts": {
        "prepare": "tsc -b",
        "build": "tsc -b"
    },
    "keywords": [
        "fluxer",
        "fluxerjs",
        "framework"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@flint.js/core": "workspace:*",
        "tsx": "^4.21.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0"
    }
}
